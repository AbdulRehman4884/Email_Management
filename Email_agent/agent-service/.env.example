# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret used to verify incoming user JWTs (HS256)
JWT_SECRET=change-me-to-a-secure-random-value-at-least-32-chars

# ── MCP server connection ─────────────────────────────────────────────────────
# Base URL of the mailflow-mcp-server SSE endpoint
MCP_SERVER_URL=http://localhost:3001/sse

# Shared secret sent as X-Service-Token to authenticate agent-service → mcp-server calls
MCP_SERVICE_SECRET=change-me-to-a-secure-random-value-at-least-32-chars

# ── LLM ───────────────────────────────────────────────────────────────────────
# Optional: Anthropic key (not required by current provider stack)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Enables OpenAI-powered intent detection and response enhancement
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_MODEL=gpt-4o-mini

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
