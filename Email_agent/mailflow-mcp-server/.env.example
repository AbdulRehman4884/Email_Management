# ────────────────────────────────────────────────
# MailFlow MCP Server — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ────────────────────────────────────────────────

# ── Node ──────────────────────────────────────────
NODE_ENV=development

# ── MCP Transport ─────────────────────────────────
# "sse" for HTTP/SSE (used by agent-service)
# "stdio" for direct stdio transport (testing / local CLI)
MCP_TRANSPORT=sse

# SSE server port (only used when MCP_TRANSPORT=sse)
MCP_SSE_PORT=3001

# SSE endpoint path (only used when MCP_TRANSPORT=sse)
MCP_SSE_ENDPOINT=/sse

# ── MailFlow API ───────────────────────────────────
# Base URL of the MailFlow backend (no trailing slash)
MAILFLOW_API_BASE_URL=http://localhost:4000/api/v1

# Request timeout in milliseconds
MAILFLOW_API_TIMEOUT_MS=10000

# ── Auth ──────────────────────────────────────────
# Service-to-service shared secret used by agent-service when calling this MCP server.
# agent-service passes this in the X-Service-Token header.
# MCP server validates it before processing any request.
# IMPORTANT: must be a securely generated secret (e.g. openssl rand -hex 32)
MCP_SERVICE_SECRET=REPLACE_WITH_SECURE_SECRET

# When acting as a service account, this JWT is used to call MailFlow APIs.
# In per-user mode, the bearer token forwarded from agent-service is used instead.
# Leave blank to rely entirely on per-request forwarded tokens.
MAILFLOW_SERVICE_ACCOUNT_TOKEN=

# ── Logging ───────────────────────────────────────
# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Set to "true" to enable pino-pretty output (development only)
LOG_PRETTY=true
