# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/email_campaigns

# SMTP (fallback if no DB settings): Gmail, Hostinger, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your@gmail.com

# Open tracking: must be a PUBLIC URL (e.g. https://your-api.com or ngrok). If not set or localhost, opens won't be recorded when recipients open emails.
TRACKING_BASE_URL=http://localhost:3000

# Optional: base URL for List-Unsubscribe link (reduces spam folder placement). If set, emails include a one-click unsubscribe link.
# UNSUBSCRIBE_BASE_URL=https://your-api.com
